# ┌─────────────────────────────────────────────────────────────────┐
# │ Environment Variables for Docker / Cloud Deployment              │
# │                                                                  │
# │ Copy to .env:  cp .env.example .env                              │
# │ Then edit and fill in your values.                               │
# │                                                                  │
# │ The entrypoint script auto-generates litellm_config.yaml         │
# │ from these vars at startup — no config file needed.              │
# └─────────────────────────────────────────────────────────────────┘

# ── Model ──────────────────────────────────────────────────────────
# Which model to use. Format: provider/model-id
# See docs/providers.md for all options
LITELLM_MODEL=deepseek/deepseek-v4-pro
# Name shown in Claude Code's /model list
LITELLM_MODEL_NAME=deepseek-v4-pro

# ── Provider API Keys (set the one for your model) ─────────────────

# DeepSeek → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key

# OpenAI → https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key

# Groq → https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-groq-key

# Google Gemini → https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-google-ai-studio-key

# OpenRouter → https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your-key

# ── Generic / Custom Providers ─────────────────────────────────────
# Use LITELLM_API_KEY for any provider not listed above
# LITELLM_API_KEY=sk-your-key
# Required if your model string includes the provider:
#   LITELLM_MODEL=your-provider/your-model

# Custom API base URL (for self-hosted / proxies)
# LITELLM_API_BASE=https://your-custom-api.com

# ── Optional ───────────────────────────────────────────────────────
# Master key to protect the proxy (prevents unauthorized use)
# LITELLM_MASTER_KEY=sk-your-secret-master-key

# Proxy port (default: 4000)
# LITELLM_PORT=4000
