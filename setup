#!/usr/bin/env bash
# ┌─────────────────────────────────────────────────────────────────┐
# │ Claude Code Custom Model Setup                                  │
# │ Interactive setup for using any LLM with Claude Code            │
# │                                                                 │
# │ Usage: bash setup                                               │
# │   or:  curl -fsSL <url>/setup | bash                            │
# └─────────────────────────────────────────────────────────────────┘

set -euo pipefail

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ── Banner ──────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║   Claude Code Custom Model Setup             ║${NC}"
echo -e "${BOLD}║   Use any LLM with Claude Code               ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
echo ""

# ── Check Prerequisites ────────────────────────────────────────────
echo -e "${BLUE}[1/5]${NC} Checking prerequisites..."

# Check Python
if command -v python3 &>/dev/null; then
    PYTHON=python3
elif command -v python &>/dev/null; then
    PYTHON=python
else
    echo -e "${RED}✗ Python 3 not found. Install it: https://python.org${NC}"
    exit 1
fi

PY_VERSION=$($PYTHON --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
echo -e "  ${GREEN}✓${NC} Python $PY_VERSION"

# Check pip or uv
INSTALL_TOOL=""  # "uv" or "pip" — controls output filtering
if command -v uv &>/dev/null; then
    if [ -n "${VIRTUAL_ENV:-}" ]; then
        INSTALL_CMD="uv pip install"
    else
        INSTALL_CMD="uv pip install --system"
    fi
    INSTALL_TOOL="uv"
    echo -e "  ${GREEN}✓${NC} uv (fast Python package manager)"
elif command -v pip3 &>/dev/null; then
    INSTALL_CMD="pip3 install --progress-bar on"
    INSTALL_TOOL="pip"
    echo -e "  ${GREEN}✓${NC} pip3"
elif command -v pip &>/dev/null; then
    INSTALL_CMD="pip install --progress-bar on"
    INSTALL_TOOL="pip"
    echo -e "  ${GREEN}✓${NC} pip"
else
    echo -e "  ${YELLOW}!${NC} No pip or uv found."
    echo ""
    echo "  pip is required to install LiteLLM. We can try to install it:"
    echo ""

    # Try ensurepip first (bundled with Python)
    PIP_INSTALLED=false
    if $PYTHON -m ensurepip --default-pip 2>/dev/null; then
        PIP_INSTALLED=true
    elif curl -fsSL https://bootstrap.pypa.io/get-pip.py | $PYTHON 2>/dev/null; then
        PIP_INSTALLED=true
    elif command -v apt-get &>/dev/null; then
        echo "  Attempting: sudo apt-get install python3-pip"
        sudo apt-get install -y python3-pip && PIP_INSTALLED=true
    fi

    if $PIP_INSTALLED; then
        # Prefer python -m pip (most reliable after ensurepip)
        if $PYTHON -m pip --version &>/dev/null; then
            INSTALL_CMD="$PYTHON -m pip install --progress-bar on"
        elif command -v pip3 &>/dev/null; then
            INSTALL_CMD="pip3 install --progress-bar on"
        elif command -v pip &>/dev/null; then
            INSTALL_CMD="pip install --progress-bar on"
        fi
        INSTALL_TOOL="pip"
        echo -e "  ${GREEN}✓${NC} pip installed"
    else
        echo -e "  ${RED}✗${NC} Could not install pip automatically."
        echo "    Install it manually: https://pip.pypa.io/en/stable/installation/"
        exit 1
    fi
fi

# PEP 668: Debian/Ubuntu block pip installs into system Python.
# PIP_BREAK_SYSTEM_PACKAGES=1 overrides this safely (env var, ignored on old pip).
if [ "$INSTALL_TOOL" = "pip" ]; then
    export PIP_BREAK_SYSTEM_PACKAGES=1
fi

# Helper: install with clean output (progress bar visible, noise hidden)
install_pkg() {
    if [ "$INSTALL_TOOL" = "pip" ]; then
        # Pip sends progress bar to stderr, package spam to stdout.
        # Merge them, filter out the per-package noise, keep the progress bar.
        $INSTALL_CMD "$@" 2>&1 | grep --line-buffered -v \
            -e "^Requirement already satisfied" \
            -e "  Downloading" \
            -e "  Installing build dependencies" \
            -e "  Getting requirements to build" \
            -e "  Preparing metadata" \
            -e "  Running setup.py" \
            -e "  Building wheel" \
            -e "^Created wheel" \
            -e "^Stored in" \
            -e "^  Stored in" \
            -e "pip is looking at multiple"
        echo ""
    else
        $INSTALL_CMD "$@"
    fi
}

# Check Claude Code
if command -v claude &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Claude Code"
else
    echo -e "  ${YELLOW}!${NC} Claude Code not found in PATH."
    echo "  (We'll set up the proxy first. Install Claude Code whenever you're ready.)"
    echo ""

    # Try brew first (macOS), then npm (Linux/any)
    if command -v brew &>/dev/null; then
        INSTALL_VIA="brew install claude-code"
    elif command -v npm &>/dev/null; then
        INSTALL_VIA="npm install -g --no-audit --no-fund @anthropic-ai/claude-code"
    elif command -v node &>/dev/null; then
        INSTALL_VIA="npm install -g --no-audit --no-fund @anthropic-ai/claude-code"
    else
        INSTALL_VIA=""
    fi

    if [ -n "$INSTALL_VIA" ]; then
        echo "  We can install it: $INSTALL_VIA"
        read -p "  Install now? [Y/n]: " INSTALL_CC < /dev/tty
        INSTALL_CC=${INSTALL_CC:-y}
        if [[ "$INSTALL_CC" =~ ^[Yy]$ ]]; then
            echo ""
            echo -e "  ${BLUE}▶${NC} Installing Claude Code..."
            $INSTALL_VIA
            echo -e "  ${GREEN}✓${NC} Claude Code installed"
        else
            echo -e "  ${YELLOW}!${NC} Skipped. We'll configure the proxy now — just install Claude Code later and run 'claude'."
            echo "    Install later: $INSTALL_VIA"
        fi
    else
        echo -e "  ${YELLOW}!${NC} Cannot auto-install Claude Code (no brew or npm found)."
        echo "    We'll configure the proxy now. Install Claude Code later, then run 'claude':"
        echo "      brew install claude-code                      # macOS"
        echo "      npm install -g @anthropic-ai/claude-code      # Linux"
        echo ""
    fi
fi

echo ""

# ── Choose Provider ────────────────────────────────────────────────
echo -e "${BLUE}[2/5]${NC} Which provider do you want to use?"
echo ""
echo "  1) DeepSeek      (deepseek-v4-pro, deepseek-chat)"
echo "  2) OpenAI        (gpt-4o, gpt-4.1, o4-mini)"
echo "  3) Groq          (llama-4-maverick, mixtral)"
echo "  4) Google Gemini (gemini-2.5-pro, gemini-2.5-flash)"
echo "  5) Ollama        (local models — llama3, mistral, etc.)"
echo "  6) OpenRouter    (200+ models via one API)"
echo "  7) Other         (any LiteLLM-supported provider)"
echo ""

# Loop until user gives valid input
PROVIDER_CHOICE=""
while [ -z "${PROVIDER_NAME:-}" ]; do
    read -p "  Enter choice [1-7]: " PROVIDER_CHOICE < /dev/tty

    case "$PROVIDER_CHOICE" in
        1)
            PROVIDER_NAME="DeepSeek"
            PROMPT_MODEL="deepseek/deepseek-v4-pro"
            PROMPT_MODEL_NAME="deepseek-v4-pro"
            PROMPT_API_KEY_LABEL="DeepSeek API key (sk-...)"
            PROMPT_API_KEY_URL="https://platform.deepseek.com/api_keys"
            ;;
        2)
            PROVIDER_NAME="OpenAI"
            PROMPT_MODEL="openai/gpt-4o"
            PROMPT_MODEL_NAME="gpt-4o"
            PROMPT_API_KEY_LABEL="OpenAI API key (sk-...)"
            PROMPT_API_KEY_URL="https://platform.openai.com/api-keys"
            ;;
        3)
            PROVIDER_NAME="Groq"
            PROMPT_MODEL="groq/meta-llama/llama-4-maverick-17b-128e-instruct"
            PROMPT_MODEL_NAME="llama-4-maverick"
            PROMPT_API_KEY_LABEL="Groq API key (gsk_...)"
            PROMPT_API_KEY_URL="https://console.groq.com/keys"
            ;;
        4)
            PROVIDER_NAME="Google Gemini"
            PROMPT_MODEL="gemini/gemini-2.5-pro-exp-03-25"
            PROMPT_MODEL_NAME="gemini-2.5-pro"
            PROMPT_API_KEY_LABEL="Gemini API key"
            PROMPT_API_KEY_URL="https://aistudio.google.com/apikey"
            ;;
        5)
            PROVIDER_NAME="Ollama"
            read -p "  Ollama model name [llama3]: " OLLAMA_MODEL < /dev/tty
            OLLAMA_MODEL=${OLLAMA_MODEL:-llama3}
            PROMPT_MODEL="ollama/$OLLAMA_MODEL"
            PROMPT_MODEL_NAME="ollama-$OLLAMA_MODEL"
            PROMPT_API_KEY_LABEL=""
            PROMPT_API_KEY_URL=""
            ;;
        6)
            PROVIDER_NAME="OpenRouter"
            PROMPT_MODEL="openrouter/anthropic/claude-sonnet-4-6"
            PROMPT_MODEL_NAME="claude-sonnet-4-6"
            PROMPT_API_KEY_LABEL="OpenRouter API key (sk-or-...)"
            PROMPT_API_KEY_URL="https://openrouter.ai/keys"
            ;;
        7)
            PROVIDER_NAME="Other"
            read -p "  Provider/model string (e.g. 'deepseek/deepseek-chat'): " PROMPT_MODEL < /dev/tty
            read -p "  Model name for Claude Code (e.g. 'my-model'): " PROMPT_MODEL_NAME < /dev/tty
            PROMPT_API_KEY_LABEL="API key"
            PROMPT_API_KEY_URL=""
            ;;
        *)
            echo -e "  ${RED}\"$PROVIDER_CHOICE\" is not a valid choice. Enter a number 1-7.${NC}"
            echo ""
            ;;
    esac
done

echo ""
echo -e "  Provider: ${GREEN}$PROVIDER_NAME${NC}"
echo ""

# ── Get API Key (skip for Ollama) ──────────────────────────────────
if [ "$PROVIDER_CHOICE" != "5" ]; then
    echo -e "${BLUE}[3/5]${NC} API Key"
    [ -n "$PROMPT_API_KEY_URL" ] && echo "  Get one at: $PROMPT_API_KEY_URL"
    echo ""

    API_KEY=""
    while [ -z "$API_KEY" ]; do
        read -sp "  $PROMPT_API_KEY_LABEL: " API_KEY < /dev/tty
        echo ""
        if [ -z "$API_KEY" ]; then
            echo -e "  ${RED}API key cannot be empty.${NC}"
        fi
    done
fi

# ── Install LiteLLM ────────────────────────────────────────────────
echo ""
echo -e "${BLUE}[4/5]${NC} Installing LiteLLM..."
echo ""
install_pkg "litellm[proxy]"

# Verify proxy dependencies are actually installed (pip sometimes skips
# extras if bare litellm was already installed from a previous run)
if ! $PYTHON -c "import websockets" 2>/dev/null; then
    echo -e "  ${YELLOW}!${NC} Missing proxy dependencies, installing..."
    install_pkg websockets
fi

# Resolve litellm command — pip may install it to ~/.local/bin which isn't always in PATH
if command -v litellm &>/dev/null; then
    LITELLM_CMD="litellm"
elif [ -x "$HOME/.local/bin/litellm" ]; then
    LITELLM_CMD="$HOME/.local/bin/litellm"
elif $PYTHON -m litellm --help &>/dev/null 2>&1; then
    LITELLM_CMD="$PYTHON -m litellm"
else
    # Last resort: find it
    LITELLM_BIN=$(find "$HOME/.local" -name litellm -type f -executable 2>/dev/null | head -1)
    if [ -n "$LITELLM_BIN" ]; then
        LITELLM_CMD="$LITELLM_BIN"
    else
        echo -e "  ${RED}✗${NC} Cannot find litellm after install. Check: pip3 show litellm"
        exit 1
    fi
fi
echo -e "  ${GREEN}✓${NC} LiteLLM installed"

# ── Generate Config ────────────────────────────────────────────────
echo ""
echo -e "${BLUE}[5/5]${NC} Generating configuration..."

# Write to home directory — always writable, avoids permission errors
# from curl-pipe-bash running in a non-writable CWD or a stale root-owned file
CONFIG_FILE="$HOME/litellm_config.yaml"
if [ -f "$CONFIG_FILE" ] && [ ! -w "$CONFIG_FILE" ]; then
    echo -e "  ${YELLOW}!${NC} Removing unwritable config from old run..."
    rm -f "$CONFIG_FILE" 2>/dev/null || true
fi

if [ "$PROVIDER_CHOICE" = "5" ]; then
    # Ollama — no API key needed
    cat > "$CONFIG_FILE" << EOF
model_list:
  - model_name: $PROMPT_MODEL_NAME
    litellm_params:
      model: $PROMPT_MODEL
      api_base: http://localhost:11434

litellm_settings:
  drop_params: true
EOF
else
    cat > "$CONFIG_FILE" << EOF
model_list:
  - model_name: $PROMPT_MODEL_NAME
    litellm_params:
      model: $PROMPT_MODEL
      api_key: $API_KEY

litellm_settings:
  drop_params: true
EOF
fi

echo -e "  ${GREEN}✓${NC} Configuration written to $CONFIG_FILE"

# ── Configure Claude Code ──────────────────────────────────────────
SETTINGS_FILE="$HOME/.claude/settings.json"

if [ -f "$SETTINGS_FILE" ]; then
    echo ""
    echo -e "  ${YELLOW}!${NC} $SETTINGS_FILE already exists."
    echo "  Existing content:"
    cat "$SETTINGS_FILE" | sed 's/^/    /'
    echo ""
    read -p "  Overwrite with proxy settings? [y/N]: " OVERWRITE < /dev/tty
    if [[ "$OVERWRITE" =~ ^[Yy]$ ]]; then
        cp "$SETTINGS_FILE" "$SETTINGS_FILE.bak"
        echo -e "  ${GREEN}✓${NC} Backed up to $SETTINGS_FILE.bak"
        cat > "$SETTINGS_FILE" << EOF
{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:4000",
    "ANTHROPIC_API_KEY": "sk-anything"
  },
  "model": "$PROMPT_MODEL_NAME"
}
EOF
        echo -e "  ${GREEN}✓${NC} Claude Code configured"
    else
        echo -e "  ${YELLOW}!${NC} Skipped. Add this to your settings.json manually:"
        echo ""
        echo '  {'
        echo '    "env": {'
        echo '      "ANTHROPIC_BASE_URL": "http://localhost:4000",'
        echo '      "ANTHROPIC_API_KEY": "sk-anything"'
        echo '    },'
        echo "    \"model\": \"$PROMPT_MODEL_NAME\""
        echo '  }'
    fi
else
    mkdir -p "$HOME/.claude"
    cat > "$SETTINGS_FILE" << EOF
{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:4000",
    "ANTHROPIC_API_KEY": "sk-anything"
  },
  "model": "$PROMPT_MODEL_NAME"
}
EOF
    echo -e "  ${GREEN}✓${NC} Claude Code configured ($SETTINGS_FILE)"
fi

# ── Start Proxy ────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║   Setup Complete!                             ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  Provider:     ${GREEN}$PROVIDER_NAME${NC}"
echo -e "  Model:        ${GREEN}$PROMPT_MODEL_NAME${NC}"
echo -e "  Config:       ${GREEN}$CONFIG_FILE${NC}"
echo ""

read -p "  Start LiteLLM proxy now? [Y/n]: " START_PROXY < /dev/tty
START_PROXY=${START_PROXY:-y}

if [[ "$START_PROXY" =~ ^[Yy]$ ]]; then
    echo ""
    echo -e "  ${GREEN}▶${NC} Starting proxy on http://localhost:4000"
    echo -e "  ${YELLOW}  Keep this terminal open. Ctrl+C to stop.${NC}"
    echo ""
    $LITELLM_CMD --config "$CONFIG_FILE" --port 4000
else
    echo ""
    echo "  To start the proxy later:"
    echo ""
    echo "    $LITELLM_CMD --config $CONFIG_FILE --port 4000"
    echo ""
    echo "  Then launch Claude Code:"
    echo ""
    echo "    claude"
    echo ""
fi
